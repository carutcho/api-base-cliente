# Banco de dados
DB_URL=jdbc:postgresql://localhost:5432/base_consulta_credito
DB_USER=appuser
DB_PASSWORD=apppassword

# JWT - gere uma chave Base64 de 256 bits para producao
# Exemplo: openssl rand -base64 32
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION_MS=86400000

# Usuario admin (criado na primeira execucao se nao existir)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# API Key para integracoes machine-to-machine (ex: n8n)
API_KEY_NAME=n8n-integration
API_KEY_VALUE=quickstart-api-key-change-me

# CORS - origens permitidas separadas por virgula
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Perfil Spring ativo (DEV, HOMOLOG, PROD)
SPRING_PROFILES_ACTIVE=DEV
